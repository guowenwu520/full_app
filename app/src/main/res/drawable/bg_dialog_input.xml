<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/color_dialog_input_bg_focused" />
            <stroke android:width="1.5dp" android:color="@color/color_primary" />
            <padding android:left="14dp" android:right="14dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/color_dialog_input_bg" />
            <stroke android:width="1dp" android:color="@color/color_dialog_input_stroke" />
            <padding android:left="14dp" android:right="14dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
</selector>
