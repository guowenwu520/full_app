<?xml version='1.0' encoding='UTF-8'?>
<!-- 运动 / 单词合并页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/transparent" android:clipToPadding="false" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="10dp" android:paddingTop="30dp" android:paddingEnd="10dp" android:paddingBottom="24dp">
        <!-- 标题 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvExerciseWordTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:includeFontPadding="false" android:text="运动与期货" android:textColor="@color/color_text_main" android:textSize="25sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvExerciseWordSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="强健体魄，稳守心境，记录每一次收益与成长。" android:textColor="@color/color_text_sub" android:textSize="12sp"/>
            </LinearLayout>
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:contentDescription="@null" android:src="@drawable/ic_ew_calendar"/>
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginStart="14dp" android:contentDescription="@null" android:background="@drawable/bg_circle_image_clip" android:clipToOutline="true" android:scaleType="centerCrop" android:src="@drawable/ic_profile_meditation"/>
        </LinearLayout>
        <!-- 页签 -->
        <!-- ==================== 运动页 ==================== -->
        <LinearLayout android:id="@+id/exercisePage" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!-- 运动统计 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="110dp" android:layout_marginTop="10dp" android:background="@drawable/bg_realm_status_card" android:clipToOutline="true" android:elevation="3dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="6dp">
                <include android:id="@+id/statTodayCalories" layout="@layout/item_ew_stat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
                <View android:layout_width="1dp" android:layout_height="58dp" android:background="@color/exp_divider"/>
                <include android:id="@+id/statMonthlyCalories" layout="@layout/item_ew_stat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
                <View android:layout_width="1dp" android:layout_height="58dp" android:background="@color/exp_divider"/>
                <include android:id="@+id/statExerciseStreak" layout="@layout/item_ew_stat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
                <View android:layout_width="1dp" android:layout_height="58dp" android:background="@color/exp_divider"/>
                <include android:id="@+id/statCurrentWeight" layout="@layout/item_ew_stat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
            </LinearLayout>
            <!-- 今日运动记录 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_realm_status_card" android:clipToOutline="true" android:elevation="3dp" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="今日运动记录" android:textColor="@color/color_text_main" android:textSize="15sp" android:textStyle="bold"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="92dp" android:layout_marginTop="7dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="76dp" android:layout_height="76dp" android:contentDescription="@null" android:src="@drawable/ic_ew_running_large"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvTodayExerciseMain" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="今日尚未记录运动" android:maxLines="1" android:textColor="@color/color_text_main" android:textSize="14sp" android:textStyle="bold"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="8dp" android:background="@drawable/bg_ew_inner" android:gravity="center" android:orientation="horizontal">
                            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="用时" android:textColor="@color/color_text_sub" android:textSize="9sp"/>
                                <TextView android:id="@+id/tvTodayExerciseDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="0 分钟" android:textColor="@color/color_text_main" android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <View android:layout_width="1dp" android:layout_height="32dp" android:background="@color/exp_divider"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="消耗" android:textColor="@color/color_text_sub" android:textSize="9sp"/>
                                <TextView android:id="@+id/tvTodayExerciseCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="0 kcal" android:textColor="@color/color_text_main" android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="106dp" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tvTodayExerciseTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="时间：--" android:textColor="@color/color_text_sub" android:textSize="9sp"/>
                        <TextView android:id="@+id/buttonAddExercise" android:layout_width="96dp" android:layout_height="40dp" android:layout_marginTop="10dp" android:background="@drawable/bg_button_primary" android:gravity="center" android:text="新增记录" android:textColor="@color/color_text_on_primary" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <!-- 近期运动历史 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_realm_status_card" android:clipToOutline="true" android:elevation="3dp" android:orientation="vertical" android:paddingStart="12dp" android:paddingTop="8dp" android:paddingEnd="12dp" android:paddingBottom="8dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="28dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="start" android:fontFamily="serif" android:gravity="center_vertical" android:text="近期运动历史" android:textColor="@color/color_text_main" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/buttonAllExercises" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="end" android:drawableEnd="@drawable/ic_arrow_right_small" android:drawablePadding="4dp" android:gravity="center" android:text="查看全部" android:textColor="@color/color_text_sub" android:textSize="9sp"/>
                </FrameLayout>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerExerciseHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:overScrollMode="never" android:scrollbars="none"/>
            </LinearLayout>
            <!-- 体重变化 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="190dp" android:layout_marginTop="10dp" android:background="@drawable/bg_realm_status_card" android:clipToOutline="true" android:elevation="3dp" android:orientation="vertical" android:padding="12dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="28dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="start" android:fontFamily="serif" android:gravity="center_vertical" android:text="体重变化" android:textColor="@color/color_text_main" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/buttonAddWeight" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="end" android:gravity="center" android:text="+ 记录体重" android:textColor="@color/checkin_done" android:textSize="10sp"/>
                </FrameLayout>
                <com.selfdiscipline.realm.view.WeightTrendView android:id="@+id/weightTrendView" android:layout_width="match_parent" android:layout_height="145dp"/>
            </LinearLayout>
            <!-- 期货收入变化 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="226dp" android:layout_marginTop="10dp" android:background="@drawable/bg_realm_status_card" android:clipToOutline="true" android:elevation="3dp" android:orientation="vertical" android:padding="12dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="28dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="start" android:fontFamily="serif" android:gravity="center_vertical" android:text="期货收入变化" android:textColor="@color/color_text_main" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/buttonAddFuturesIncome" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="end" android:gravity="center" android:text="+ 记录收入" android:textColor="@color/checkin_done" android:textSize="10sp"/>
                </FrameLayout>
                <TextView android:id="@+id/tvFuturesIncomeSummary" android:layout_width="match_parent" android:layout_height="24dp" android:gravity="center_vertical" android:text="累计 0 元 · 今日 0 元" android:textColor="@color/color_text_sub" android:textSize="10sp"/>
                <com.selfdiscipline.realm.view.IncomeTrendView android:id="@+id/futuresIncomeTrendView" android:layout_width="match_parent" android:layout_height="145dp"/>
            </LinearLayout>
        </LinearLayout>
        <!-- ==================== 单词页 ==================== -->
    </LinearLayout>
</ScrollView>
