<?xml version="1.0" encoding="utf-8"?>
<!-- 运动 / 单词合并页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="30dp"
        android:paddingEnd="10dp"
        android:paddingBottom="24dp">

        <!-- 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvExerciseWordTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:text="运动"
                    android:textColor="@color/color_text_main"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvExerciseWordSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="动若灵风，体魄强健，方能御风而行。"
                    android:textColor="@color/color_text_sub"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_ew_calendar" />

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_meditation" />
        </LinearLayout>

        <!-- 页签 -->
        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ew_tabs"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/buttonExerciseTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_ew_tab_selected"
                android:gravity="center"
                android:text="运动"
                android:textColor="@color/color_text_main"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/buttonWordTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="单词"
                android:textColor="@color/color_text_sub"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ==================== 运动页 ==================== -->
        <LinearLayout
            android:id="@+id/exercisePage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 运动统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp">

                <include
                    android:id="@+id/statTodayCalories"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statMonthlyCalories"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statExerciseStreak"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statCurrentWeight"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- 今日运动记录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="今日运动记录"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginTop="7dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_ew_running_large" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTodayExerciseMain"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="今日尚未记录运动"
                            android:textColor="@color/color_text_main"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_ew_inner"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="用时"
                                    android:textColor="@color/color_text_sub"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/tvTodayExerciseDuration"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="0 分钟"
                                    android:textColor="@color/color_text_main"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="32dp"
                                android:background="@color/exp_divider" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="消耗"
                                    android:textColor="@color/color_text_sub"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/tvTodayExerciseCalories"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="0 kcal"
                                    android:textColor="@color/color_text_main"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="106dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTodayExerciseTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="时间：--"
                            android:textColor="@color/color_text_sub"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/buttonAddExercise"
                            android:layout_width="96dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_button_primary"
                            android:gravity="center"
                            android:text="新增记录"
                            android:textColor="@color/color_text_on_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 近期运动历史 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:fontFamily="serif"
                        android:gravity="center_vertical"
                        android:text="近期运动历史"
                        android:textColor="@color/color_text_main"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/buttonAllExercises"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:drawableEnd="@drawable/ic_arrow_right_small"
                        android:drawablePadding="4dp"
                        android:gravity="center"
                        android:text="查看全部"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />
                </FrameLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerExerciseHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:scrollbars="none" />
            </LinearLayout>

            <!-- 体重变化 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="12dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:fontFamily="serif"
                        android:gravity="center_vertical"
                        android:text="体重变化"
                        android:textColor="@color/color_text_main"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/buttonAddWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:text="+ 记录体重"
                        android:textColor="@color/checkin_done"
                        android:textSize="10sp" />
                </FrameLayout>

                <com.selfdiscipline.realm.view.WeightTrendView
                    android:id="@+id/weightTrendView"
                    android:layout_width="match_parent"
                    android:layout_height="145dp" />
            </LinearLayout>

            <!-- 本周目标 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="104dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="本周目标"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/goalExerciseCount"
                        layout="@layout/item_ew_goal"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="42dp"
                        android:background="@color/exp_divider" />

                    <include
                        android:id="@+id/goalWeightCount"
                        layout="@layout/item_ew_goal"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="42dp"
                        android:background="@color/exp_divider" />

                    <include
                        android:id="@+id/goalCalories"
                        layout="@layout/item_ew_goal"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== 单词页 ==================== -->
        <LinearLayout
            android:id="@+id/wordPage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 单词统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_realm_status_card"
                android:clipToOutline="true"
                android:elevation="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp">

                <include
                    android:id="@+id/statWordTotal"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statWordStreak"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statWordToday"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="58dp"
                    android:background="@color/exp_divider" />

                <include
                    android:id="@+id/statWordReviewed"
                    layout="@layout/item_ew_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- 今日背词 + 抽查 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="304dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_realm_status_card"
                    android:clipToOutline="true"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="start"
                            android:fontFamily="serif"
                            android:gravity="center_vertical"
                            android:text="今日背词"
                            android:textColor="@color/color_text_main"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTodayWordProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="end"
                            android:gravity="center"
                            android:text="0/18"
                            android:textColor="@color/color_text_sub"
                            android:textSize="10sp" />
                    </FrameLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerTodayWords"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:overScrollMode="never"
                        android:scrollbars="none" />

                    <TextView
                        android:id="@+id/buttonAddWord"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_primary"
                        android:gravity="center"
                        android:text="新增单词  ＋"
                        android:textColor="@color/color_text_on_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_realm_status_card"
                    android:clipToOutline="true"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="start"
                            android:fontFamily="serif"
                            android:gravity="center_vertical"
                            android:text="随机抽查自测"
                            android:textColor="@color/color_text_main"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="end|center_vertical"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="@color/color_text_sub"
                            android:textSize="11sp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Word"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvQuizWord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="暂无单词"
                        android:textColor="@color/color_text_main"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="释义选项"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <RadioGroup
                        android:id="@+id/quizOptions"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/quizOptionA"
                            style="@style/ExerciseWordQuizOption"
                            android:text="A  --" />

                        <RadioButton
                            android:id="@+id/quizOptionB"
                            style="@style/ExerciseWordQuizOption"
                            android:text="B  --" />

                        <RadioButton
                            android:id="@+id/quizOptionC"
                            style="@style/ExerciseWordQuizOption"
                            android:text="C  --" />

                        <RadioButton
                            android:id="@+id/quizOptionD"
                            style="@style/ExerciseWordQuizOption"
                            android:text="D  --" />
                    </RadioGroup>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="完成抽查可得 +8 经验"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/buttonStartQuiz"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_button_primary"
                        android:gravity="center"
                        android:text="开始抽查"
                        android:textColor="@color/color_text_on_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 最近记录 + 背词日历 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_realm_status_card"
                    android:clipToOutline="true"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="start"
                            android:fontFamily="serif"
                            android:gravity="center_vertical"
                            android:text="最近记录"
                            android:textColor="@color/color_text_main"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/buttonAllWords"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="end"
                            android:drawableEnd="@drawable/ic_arrow_right_small"
                            android:drawablePadding="4dp"
                            android:gravity="center"
                            android:text="全部"
                            android:textColor="@color/color_text_sub"
                            android:textSize="9sp" />
                    </FrameLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerRecentWords"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:scrollbars="none" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_realm_status_card"
                    android:clipToOutline="true"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="背词日历"
                        android:textColor="@color/color_text_main"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWordCalendarStreak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:text="连续背词 0 天"
                        android:textColor="@color/color_text_main"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/wordWeekDays"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:orientation="horizontal" />

                    <TextView
                        android:id="@+id/tvWeekWordProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="本周进度     0/7 天"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <ProgressBar
                        android:id="@+id/progressWordWeek"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="7dp"
                        android:layout_marginTop="5dp"
                        android:max="7"
                        android:progressDrawable="@drawable/progress_realm" />

                    <TextView
                        android:id="@+id/tvMonthWordCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="本月已背词 0 个"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <com.selfdiscipline.realm.view.WordMonthBarChartView
                        android:id="@+id/wordMonthBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
