<?xml version="1.0" encoding="utf-8"?>
<!-- 日记自律主页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/diaryScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="28dp"
        android:paddingEnd="14dp"
        android:paddingBottom="120dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:text="日记自律"
                    android:textColor="@color/color_text_main"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="日日省身，心境自明"
                    android:textColor="@color/color_text_sub"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/buttonDiaryCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="查看全部日记"
                android:src="@drawable/ic_ew_calendar" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:background="@drawable/bg_circle_image_clip"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_meditation" />
        </LinearLayout>

        <!-- 四项统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp">

            <include
                android:id="@+id/statCurrentNoBreak"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statMonthlyBroken"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statDiaryTotal"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statTodayDiaryExp"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- 今日状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_core_no_break"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="今日状态"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="今日是否破戒："
                    android:textColor="@color/color_text_main"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_diary_toggle_group"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/buttonNotBroken"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_diary_toggle_selected"
                        android:gravity="center"
                        android:text="否"
                        android:textColor="@color/color_text_on_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/buttonBroken"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="是"
                        android:textColor="@color/color_text_main"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTodayStatusHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="今日默认未破戒；发生破戒时点击“是”立即记录"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 作息打卡 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_exp_sleep"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="作息打卡"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSleepRecordHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="23:30 前入睡，8:30 前起床即为达标"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/buttonPickSleepTime"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_inner"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="入睡时间"
                        android:textColor="@color/color_text_sub"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvSleepTimeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="22:30"
                        android:textColor="@color/color_text_main"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonPickWakeTime"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_inner"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="起床时间"
                        android:textColor="@color/color_text_sub"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvWakeTimeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="07:00"
                        android:textColor="@color/color_text_main"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSleepPassStatus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="作息达标，可获得 +15 经验"
                    android:textColor="@color/checkin_done"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonSaveSleepRecord"
                    android:layout_width="128dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="保存作息"
                    android:textColor="@color/color_text_on_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 写日记：跳转到独立页面 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_exp_diary"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="写日记"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDiaryWriteHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="点击进入独立页面记录今日心境"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/buttonOpenDiaryEditor"
                android:layout_width="180dp"
                android:layout_height="42dp"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_primary"
                android:gravity="center"
                android:text="写今日日记"
                android:textColor="@color/color_text_on_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 最近日记 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:drawableStart="@drawable/ic_exp_diary"
                    android:drawablePadding="6dp"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="最近日记"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonAllDiaries"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="全部"
                    android:textColor="@color/color_text_sub"
                    android:textSize="9sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyDiaries"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="暂无日记记录"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentDiaries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
