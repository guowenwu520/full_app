<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="156dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_realm_status_card"
    android:clipToOutline="true"
    android:elevation="3dp"
    android:padding="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 左侧境界徽章 -->
        <ImageView
            android:id="@+id/ivRealmBadge"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="@string/realm_badge"
            android:scaleType="fitCenter"
            android:src="@drawable/realm_badge_zhuji"
            app:layout_constraintBottom_toBottomOf="@id/tvRealmPercent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="UseAppTint" />

        <!-- 竖向分割线 -->
        <View
            android:id="@+id/verticalDivider"
            android:layout_width="1dp"
            android:layout_height="108dp"
            android:layout_marginStart="10dp"
            android:background="#3A9CB5C7"
            app:layout_constraintBottom_toBottomOf="@id/ivRealmBadge"
            app:layout_constraintStart_toEndOf="@id/ivRealmBadge"
            app:layout_constraintTop_toTopOf="@id/ivRealmBadge" />

        <!-- 当前境界 -->
        <TextView
            android:id="@+id/tvRealmLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/current_realm"
            android:textColor="@color/realm_text_secondary"
            android:textSize="10sp"
            app:layout_constraintStart_toEndOf="@id/verticalDivider"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 境界名称 -->
        <TextView
            android:id="@+id/tvRealmName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="serif"
            android:includeFontPadding="false"
            android:text="@string/realm_zhuji_middle"
            android:textColor="@color/realm_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvRealmLabel"
            app:layout_constraintTop_toBottomOf="@id/tvRealmLabel" />

        <!-- 境界小标 -->
        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/realm_stage_icon"
            android:src="@drawable/ic_realm_stage"
            app:layout_constraintBottom_toBottomOf="@id/tvRealmName"
            app:layout_constraintStart_toEndOf="@id/tvRealmName"
            app:layout_constraintTop_toTopOf="@id/tvRealmName"
            tools:ignore="UseAppTint" />

        <!-- 总经验 -->
        <LinearLayout
            android:id="@+id/groupTotalExp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/tvRealmLabel"
            app:layout_constraintTop_toBottomOf="@id/tvRealmName">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/total_exp"
                android:textColor="@color/realm_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTotalExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="6,280"
                android:textColor="@color/realm_accent_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- 距离下一境界 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/groupTotalExp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/groupTotalExp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/to_next_realm"
                android:textColor="@color/realm_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvRemainingExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="1,720"
                android:textColor="@color/realm_accent_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- 境界升级进度 -->
        <ProgressBar
            android:id="@+id/progressRealm"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_realm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvRealmLabel"
            app:layout_constraintTop_toBottomOf="@id/groupTotalExp" />

        <!-- 左装饰线 -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="7dp"
            android:background="#7CA8BBC9"
            app:layout_constraintEnd_toStartOf="@id/tvRealmPercent"
            app:layout_constraintStart_toStartOf="@id/progressRealm"
            app:layout_constraintTop_toBottomOf="@id/progressRealm" />

        <TextView
            android:id="@+id/tvRealmPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="2dp"
            android:text="78.4%"
            android:textColor="@color/realm_text_secondary"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="@id/progressRealm"
            app:layout_constraintEnd_toEndOf="@id/progressRealm"
            app:layout_constraintTop_toBottomOf="@id/progressRealm"
            tools:ignore="HardcodedText" />

        <!-- 右装饰线 -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="7dp"
            android:background="#7CA8BBC9"
            app:layout_constraintEnd_toEndOf="@id/progressRealm"
            app:layout_constraintStart_toEndOf="@id/tvRealmPercent"
            app:layout_constraintTop_toBottomOf="@id/progressRealm" />

        <!-- 境界描述 -->
        <TextView
            android:id="@+id/tvRealmDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/realm_zhuji_middle_desc"
            android:textColor="@color/realm_text_secondary"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRealmPercent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
