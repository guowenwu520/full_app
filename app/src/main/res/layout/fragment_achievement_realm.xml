<?xml version="1.0" encoding="utf-8"?>
<!-- 勋章与境界主页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="28dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp">

        <!-- 页面标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:text="勋章 &amp; 境界"
                    android:textColor="@color/color_text_main"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="自律修行，勋章为证，境界为阶，步步登仙"
                    android:textColor="@color/color_text_sub"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/buttonAchievementCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="查看经验明细"
                android:src="@drawable/ic_ew_calendar" />

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_meditation" />
        </LinearLayout>

        <!-- 当前境界 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/ivAchievementRealmEmblem"
                android:layout_width="126dp"
                android:layout_height="126dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_realm_stage_foundation" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前境界："
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvAchievementRealmName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:text="筑基中期"
                    android:textColor="@color/color_text_main"
                    android:textSize="27sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总经验  "
                        android:textColor="@color/color_text_sub"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvAchievementTotalXp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0"
                        android:textColor="@color/checkin_done"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="距离下一境  "
                        android:textColor="@color/color_text_sub"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvAchievementRemainingXp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/checkin_done"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressAchievementRealm"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="9dp"
                    android:layout_marginTop="7dp"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_realm" />

                <TextView
                    android:id="@+id/tvAchievementRealmPercent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0.00%"
                    android:textColor="@color/color_text_sub"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvAchievementRealmDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 境界总览 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="126dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="7dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="境界总览"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRealmStages"
                android:layout_width="match_parent"
                android:layout_height="94dp"
                android:layout_marginTop="3dp"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

        <!-- 勋章收藏墙 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="勋章收藏墙"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUnlockedMedalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:gravity="center"
                    android:text="已获 0 枚"
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMedalWall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

        <!-- 经验明细 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="经验明细"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonAllExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="全部"
                    android:textColor="@color/color_text_sub"
                    android:textSize="9sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyExperience"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="暂无经验记录"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerExperienceDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
