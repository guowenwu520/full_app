<?xml version="1.0" encoding="utf-8"?>
<!-- 今日可获取经验卡片：ConstraintLayout 版本 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_realm_status_card"
    android:clipToOutline="true"
    android:elevation="3dp"
    android:paddingStart="14dp"
    android:paddingTop="6dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTodayExpTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:includeFontPadding="false"
        android:text="@string/today_available_exp"
        android:textColor="@color/checkin_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <!-- 阅读 -->
    <ImageView
        android:id="@+id/ivReadingExp"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="6dp"
        android:contentDescription="@string/checkin_reading"
        android:src="@drawable/ic_exp_reading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTodayExpTitle" />

    <TextView
        android:id="@+id/tvReadingExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/checkin_reading"
        android:textColor="@color/exp_text_secondary"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/ivReadingExp"
        app:layout_constraintEnd_toStartOf="@id/tvReadingExpValue"
        app:layout_constraintStart_toEndOf="@id/ivReadingExp"
        app:layout_constraintTop_toTopOf="@id/ivReadingExp" />

    <TextView
        android:id="@+id/tvReadingExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+10"
        android:textColor="@color/checkin_done"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvReadingExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/dividerReading"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="3dp"
        android:background="@color/exp_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivReadingExp" />

    <!-- 运动 -->
    <ImageView
        android:id="@+id/ivExerciseExp"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="3dp"
        android:contentDescription="@string/checkin_exercise"
        android:src="@drawable/ic_exp_exercise"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerReading" />

    <TextView
        android:id="@+id/tvExerciseExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/checkin_exercise"
        android:textColor="@color/exp_text_secondary"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/ivExerciseExp"
        app:layout_constraintEnd_toStartOf="@id/tvExerciseExpValue"
        app:layout_constraintStart_toEndOf="@id/ivExerciseExp"
        app:layout_constraintTop_toTopOf="@id/ivExerciseExp" />

    <TextView
        android:id="@+id/tvExerciseExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+10"
        android:textColor="@color/checkin_done"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvExerciseExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/dividerExercise"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="3dp"
        android:background="@color/exp_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivExerciseExp" />

    <!-- 作息 -->
    <ImageView
        android:id="@+id/ivSleepExp"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="3dp"
        android:contentDescription="@string/checkin_sleep"
        android:src="@drawable/ic_exp_sleep"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerExercise" />

    <TextView
        android:id="@+id/tvSleepExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/checkin_sleep"
        android:textColor="@color/exp_text_secondary"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/ivSleepExp"
        app:layout_constraintEnd_toStartOf="@id/tvSleepExpValue"
        app:layout_constraintStart_toEndOf="@id/ivSleepExp"
        app:layout_constraintTop_toTopOf="@id/ivSleepExp" />

    <TextView
        android:id="@+id/tvSleepExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+15"
        android:textColor="@color/checkin_done"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvSleepExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/dividerSleep"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="3dp"
        android:background="@color/exp_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivSleepExp" />

    <!-- 单词 -->
    <ImageView
        android:id="@+id/ivWordExp"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="3dp"
        android:contentDescription="@string/checkin_word"
        android:src="@drawable/ic_exp_word"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerSleep" />

    <TextView
        android:id="@+id/tvWordExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/checkin_word"
        android:textColor="@color/exp_text_secondary"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/ivWordExp"
        app:layout_constraintEnd_toStartOf="@id/tvWordExpValue"
        app:layout_constraintStart_toEndOf="@id/ivWordExp"
        app:layout_constraintTop_toTopOf="@id/ivWordExp" />

    <TextView
        android:id="@+id/tvWordExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+8"
        android:textColor="@color/checkin_done"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvWordExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/dividerWord"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="3dp"
        android:background="@color/exp_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivWordExp" />

    <!-- 日记 -->
    <ImageView
        android:id="@+id/ivDiaryExp"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="3dp"
        android:contentDescription="@string/checkin_diary"
        android:src="@drawable/ic_exp_diary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerWord" />

    <TextView
        android:id="@+id/tvDiaryExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/checkin_diary"
        android:textColor="@color/exp_text_secondary"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/ivDiaryExp"
        app:layout_constraintEnd_toStartOf="@id/tvDiaryExpValue"
        app:layout_constraintStart_toEndOf="@id/ivDiaryExp"
        app:layout_constraintTop_toTopOf="@id/ivDiaryExp" />

    <TextView
        android:id="@+id/tvDiaryExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+12"
        android:textColor="@color/checkin_done"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvDiaryExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <View
        android:id="@+id/dividerDiary"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="3dp"
        android:background="@color/exp_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivDiaryExp" />

    <!-- 全完成额外奖励 -->
    <ImageView
        android:id="@+id/ivAllCompleteExp"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/all_complete_bonus"
        android:src="@drawable/ic_exp_all_complete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerDiary" />

    <TextView
        android:id="@+id/tvAllCompleteExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/all_complete_bonus"
        android:textColor="@color/exp_bonus_text"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivAllCompleteExp"
        app:layout_constraintEnd_toStartOf="@id/tvAllCompleteExpValue"
        app:layout_constraintStart_toEndOf="@id/ivAllCompleteExp"
        app:layout_constraintTop_toTopOf="@id/ivAllCompleteExp" />

    <TextView
        android:id="@+id/tvAllCompleteExpValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+50"
        android:textColor="@color/checkin_done"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvAllCompleteExpName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

</androidx.constraintlayout.widget.ConstraintLayout>
