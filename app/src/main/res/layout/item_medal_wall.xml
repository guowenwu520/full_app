<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="112dp"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="2dp">

    <TextView
        android:id="@+id/tvMedalCategory"
        android:layout_width="match_parent"
        android:layout_height="17dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/color_text_main"
        android:textSize="8sp" />

    <FrameLayout
        android:layout_width="54dp"
        android:layout_height="54dp">

        <ImageView
            android:id="@+id/ivMedalIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivMedalLock"
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:layout_gravity="bottom|end"
            android:contentDescription="@null"
            android:src="@drawable/ic_medal_lock"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvMedalTier"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/color_text_main"
        android:textSize="9sp" />

    <TextView
        android:id="@+id/tvMedalProgress"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/color_text_sub"
        android:textSize="7sp" />
</LinearLayout>
