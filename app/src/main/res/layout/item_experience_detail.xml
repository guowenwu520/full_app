<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="42dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="3dp">

    <TextView
        android:id="@+id/tvExperienceDate"
        android:layout_width="54dp"
        android:layout_height="wrap_content"
        android:textColor="@color/color_text_sub"
        android:textSize="9sp" />

    <ImageView
        android:id="@+id/ivExperienceSourceIcon"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tvExperienceSource"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/color_text_main"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/tvExperiencePoints"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/checkin_done"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
