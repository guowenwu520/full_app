<?xml version="1.0" encoding="utf-8"?>
<!-- 书籍详情页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bookDetailScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_book_detail_page"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="24dp">

        <!-- 顶部工具栏 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="42dp">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="start|center_vertical"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/book_detail_back"
                android:padding="10dp"
                android:src="@drawable/ic_book_detail_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/book_detail_title"
                android:textColor="@color/color_text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/buttonShareBook"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="end|center_vertical"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/book_detail_share"
                android:padding="10dp"
                android:src="@drawable/ic_book_detail_share" />
        </FrameLayout>

        <!-- 书籍信息 -->
        <LinearLayout
            android:id="@+id/bookInfoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:id="@+id/ivDetailBookCover"
                android:layout_width="126dp"
                android:layout_height="178dp"
                android:background="@drawable/bg_book_cover_placeholder"
                android:contentDescription="@string/book_cover"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDetailBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="@color/color_text_main"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDetailBookAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_main"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvDetailBookGenre"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_book_detail_chip"
                        android:gravity="center"
                        android:minWidth="48dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/color_primary_dark"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/statCurrentPage"
                        layout="@layout/item_book_detail_stat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/exp_divider" />

                    <include
                        android:id="@+id/statTotalPages"
                        layout="@layout/item_book_detail_stat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/exp_divider" />

                    <include
                        android:id="@+id/statReadingPercent"
                        layout="@layout/item_book_detail_stat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBookDetail"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="9dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_realm" />

                <TextView
                    android:id="@+id/tvBookDetailPercentBelow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/color_text_sub"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvBookLastUpdated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@drawable/ic_book_detail_clock"
                    android:drawablePadding="6dp"
                    android:textColor="@color/color_text_sub"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/buttonUpdateBookPage"
                style="@style/BookDetailActionButton"
                android:drawableStart="@drawable/ic_book_detail_update"
                android:text="@string/button_update_page" />

            <TextView
                android:id="@+id/buttonNewPageNote"
                style="@style/BookDetailActionButton"
                android:layout_marginStart="8dp"
                android:drawableStart="@drawable/ic_page_note_small"
                android:text="@string/button_page_note" />

            <TextView
                android:id="@+id/buttonWriteBookReview"
                style="@style/BookDetailActionButton"
                android:layout_marginStart="8dp"
                android:drawableStart="@drawable/ic_book_detail_review"
                android:text="@string/button_full_review" />
        </LinearLayout>

        <!-- 分页批注 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="@string/page_notes"
                    android:textColor="@color/color_text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonToggleAllNotes"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="@string/all_page_notes"
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyPageNotes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="@string/empty_page_notes"
                android:textColor="@color/color_text_sub"
                android:textSize="11sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBookPageNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

        <!-- 全书读后感 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="@string/book_reflection"
                    android:textColor="@color/color_text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonViewFullReview"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="@string/view_full_review"
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_exp_reading" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBookReviewHeading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/color_text_main"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBookReviewPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="3"
                        android:textColor="@color/color_text_sub"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 阅读历史 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="@string/reading_history"
                    android:textColor="@color/color_text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonToggleAllHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="@string/all_history"
                    android:textColor="@color/color_text_sub"
                    android:textSize="10sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyReadingHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="@string/empty_reading_history"
                android:textColor="@color/color_text_sub"
                android:textSize="11sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBookReadingHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
