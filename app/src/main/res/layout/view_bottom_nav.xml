<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_nav_hud"
    android:paddingTop="2dp"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/nav_overview"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/nav_overview_image"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_nav_home" />

        <TextView
            android:id="@+id/nav_overview_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/nav_overview_ref"
            android:textColor="@color/color_text_sub"
            android:textSize="12sp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/nav_reading"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/nav_reading_image"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_nav_reading" />

        <TextView
            android:id="@+id/nav_reading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_reading"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/color_text_sub"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_study"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/nav_study_image"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_nav_exercise_word" />

        <TextView
            android:id="@+id/nav_study_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_study"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/color_text_sub"
            android:textSize="12sp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/nav_diary"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/nav_diary_image"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_nav_diary" />

        <TextView
            android:id="@+id/nav_diary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_diary"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/color_text_sub"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_badges"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/nav_badges_image"
            android:layout_width="35dp"
            android:layout_gravity="center_horizontal"
            android:layout_height="35dp"
            android:src="@drawable/ic_nav_medal_realm" />

        <TextView
            android:id="@+id/nav_badges_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/nav_badges"
            android:textColor="@color/color_text_sub"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
