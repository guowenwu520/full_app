<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_realm_status_card"
    android:clipToOutline="true"
    android:elevation="3dp"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="11dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:text="今日打卡进度"
            android:textColor="@color/checkin_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCheckinCount"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="center_vertical"
            android:text="1/4"
            android:textColor="@color/checkin_done"
            android:textSize="10sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivReadingStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="阅读"
                android:src="@drawable/ic_checkin_reading_pending" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="阅读"
                android:textColor="@color/checkin_text_primary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvReadingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待完成"
                android:textColor="@color/checkin_pending"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivExerciseStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="运动"
                android:src="@drawable/ic_checkin_exercise_pending" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="运动"
                android:textColor="@color/checkin_text_primary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvExerciseStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待完成"
                android:textColor="@color/checkin_pending"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/exp_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivSleepStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="作息"
                android:src="@drawable/ic_checkin_sleep_pending" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="作息"
                android:textColor="@color/checkin_text_primary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSleepStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待完成"
                android:textColor="@color/checkin_pending"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivDiaryStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="破戒状态"
                android:src="@drawable/ic_checkin_diary_done" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="破戒"
                android:textColor="@color/checkin_text_primary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvDiaryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未破戒"
                android:textColor="@color/checkin_done"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
