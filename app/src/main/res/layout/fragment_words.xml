<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/transparent" android:fillViewport="true" android:clipToPadding="false">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingLeft="18dp" android:paddingRight="18dp" android:paddingTop="28dp" android:paddingBottom="18dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="12dp" android:background="@drawable/bg_header_fade" android:padding="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/text_app_brand" android:textColor="@color/color_text_sub" android:textSize="14sp" android:drawableStart="@drawable/ic_app_icon" android:drawablePadding="8dp" android:gravity="center_vertical" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/title_words" android:textColor="@color/color_text_main" android:textSize="34sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginTop="8dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/subtitle_words_refined" android:textColor="@color/color_text_sub" android:textSize="16sp" android:layout_marginTop="4dp" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:text="@string/text_words_hint" android:textColor="@color/color_text_sub" android:textSize="15sp" android:drawableStart="@drawable/ic_nav_word" android:drawablePadding="10dp" android:gravity="center_vertical" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/section_words" android:textColor="@color/color_text_main" android:textStyle="bold" android:textSize="20sp" android:fontFamily="serif" android:layout_marginTop="14dp" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card">
            <EditText android:id="@+id/input_word" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_input" android:hint="@string/hint_word" android:inputType="text" android:textColor="@color/color_text_main" android:textColorHint="@color/color_text_sub" />
            <EditText android:id="@+id/input_meaning" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_input" android:hint="@string/hint_meaning" android:inputType="text" android:textColor="@color/color_text_main" android:textColorHint="@color/color_text_sub" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/button_add_word" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_button_primary" android:gravity="center" android:text="@string/button_add_word" android:textColor="@color/color_text_on_primary" android:textStyle="bold" />
                <TextView android:id="@+id/button_random_test" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" android:background="@drawable/bg_button_soft" android:gravity="center" android:text="@string/button_random_test" android:textColor="@color/color_primary_dark" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/section_recent_words" android:textColor="@color/color_text_main" android:textStyle="bold" android:textSize="20sp" android:fontFamily="serif" android:layout_marginTop="14dp" android:layout_marginBottom="8dp" />
        <TextView android:id="@+id/button_view_all_words" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:background="@drawable/bg_button_soft" android:gravity="center" android:text="@string/button_view_all_words" android:textColor="@color/color_primary_dark" android:textStyle="bold" />
        <LinearLayout android:id="@+id/word_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
