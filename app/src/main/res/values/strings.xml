    <string name="desc_qi_early">初入自律之路，偶尔懈怠，正在养成基础打卡习惯</string>
    <string name="desc_qi_mid">逐步固定每日任务，偶尔断签，但已有向上之心</string>
    <string name="desc_qi_late">能稳定完成2-3项日常自律，自控力小幅提升</string>
    <string name="desc_qi_peak">极少破戒，作息、阅读基本稳定，初具恒心</string>
    <string name="desc_foundation_early">多数日子全模块打卡，连续自律天数稳步上涨</string>
    <string name="desc_foundation_mid">体重、阅读与收益记录长期坚持，收获第一批白银勋章</string>
    <string name="desc_foundation_late">极少中断自律，自控力显著提升，很少破戒</string>
    <string name="desc_foundation_peak">作息常年达标，运动阅读形成肌肉记忆</string>
    <string name="desc_core_early">解锁多类黄金勋章，长期保持多维度连续打卡</string>
    <string name="desc_core_mid">体重稳步下降、阅读量持续积累，期货收益记录逐渐丰厚</string>
    <string name="desc_core_late">全年极少断签，自律成为日常本能</string>
    <string name="desc_core_peak">集齐大半品类勋章，意志力远超常人</string>
    <string name="desc_soul_early">解锁铂金勋章，长期无破戒记录，生活高度规律</string>
    <string name="desc_soul_mid">体重曲线持续向好，阅读、运动、学习全面丰收</string>
    <string name="desc_soul_late">全年连续自律天数时常破百，内心极度自律平和</string>
    <string name="desc_soul_peak">仅差少量王者勋章，自我管理近乎完美</string>
    <string name="desc_spirit_early">解锁首枚王者勋章，多维度长期坚持无断层</string>
    <string name="desc_spirit_mid">集齐绝大多数勋章，数年稳定自律，彻底摆脱拖延</string>
    <string name="desc_spirit_late">所有自律习惯完全刻入生活，无需刻意约束自己</string>
    <string name="desc_spirit_peak">自律大道圆满，知行合一，自我提升达到极致</string>


