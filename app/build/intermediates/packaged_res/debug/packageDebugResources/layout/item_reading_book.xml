<?xml version="1.0" encoding="utf-8"?>
<!-- 书架单条 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="4dp">

    <ImageView
        android:id="@+id/ivBookCover"
        android:layout_width="46dp"
        android:layout_height="62dp"
        android:background="@drawable/bg_book_cover_placeholder"
        android:contentDescription="@string/book_cover"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_text_main"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBookAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_text_sub"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBookProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/color_text_sub"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/progressBook"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="82dp"
            android:layout_height="6dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progressDrawable="@drawable/progress_realm" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvBookStatus"
        android:layout_width="42dp"
        android:layout_height="28dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_reading_chip_active"
        android:gravity="center"
        android:textColor="@color/color_primary_dark"
        android:textSize="10sp" />

    <ImageView
        android:id="@+id/ivBookMore"
        android:layout_width="26dp"
        android:layout_height="34dp"
        android:contentDescription="@string/more"
        android:padding="8dp"
        android:src="@drawable/ic_more_vertical_small" />
</LinearLayout>
