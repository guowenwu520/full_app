<?xml version="1.0" encoding="utf-8"?>
<!-- 日记自律主页 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="28dp"
        android:paddingEnd="14dp"
        android:paddingBottom="24dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:includeFontPadding="false"
                    android:text="日记自律"
                    android:textColor="@color/color_text_main"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="日日省身，心境自明"
                    android:textColor="@color/color_text_sub"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/buttonDiaryCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="查看全部日记"
                android:src="@drawable/ic_ew_calendar" />

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_meditation" />
        </LinearLayout>

        <!-- 四项统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp">

            <include
                android:id="@+id/statCurrentNoBreak"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statMonthlyBroken"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statDiaryTotal"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="54dp"
                android:background="@color/exp_divider" />

            <include
                android:id="@+id/statTodayDiaryExp"
                layout="@layout/item_diary_stat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- 今日状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_core_no_break"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="今日状态"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="7dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="今日是否破戒："
                    android:textColor="@color/color_text_main"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="180dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_diary_toggle_group"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/buttonNotBroken"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_diary_toggle_selected"
                        android:gravity="center"
                        android:text="否"
                        android:textColor="@color/color_text_on_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/buttonBroken"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="是"
                        android:textColor="@color/color_text_main"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTodayStatusHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="保持本心，记录今日修行感悟"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 写日记 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_exp_diary"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="写日记"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputDiaryTitle"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_diary_input"
                android:hint="标题：记录今日的心境"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/color_text_main"
                android:textColorHint="@color/color_text_sub"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/inputDiaryBody"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_diary_input"
                android:gravity="top|start"
                android:hint="正文：写下今天发生的事情、感受与反思……"
                android:inputType="textCapSentences|textMultiLine"
                android:padding="12dp"
                android:scrollbars="vertical"
                android:textColor="@color/color_text_main"
                android:textColorHint="@color/color_text_sub"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/buttonSaveDiary"
                android:layout_width="156dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_button_primary"
                android:gravity="center"
                android:text="保存今日日记"
                android:textColor="@color/color_text_on_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 最近日记 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:drawableStart="@drawable/ic_exp_diary"
                    android:drawablePadding="6dp"
                    android:fontFamily="serif"
                    android:gravity="center_vertical"
                    android:text="最近日记"
                    android:textColor="@color/color_text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonAllDiaries"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:drawableEnd="@drawable/ic_arrow_right_small"
                    android:drawablePadding="4dp"
                    android:gravity="center"
                    android:text="全部"
                    android:textColor="@color/color_text_sub"
                    android:textSize="9sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyDiaries"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="暂无日记记录"
                android:textColor="@color/color_text_sub"
                android:textSize="10sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecentDiaries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:scrollbars="none" />
        </LinearLayout>

        <!-- 长期统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="106dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_realm_status_card"
            android:clipToOutline="true"
            android:elevation="3dp"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="9dp"
            android:paddingEnd="14dp"
            android:paddingBottom="9dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_core_streak"
                android:drawablePadding="7dp"
                android:fontFamily="serif"
                android:gravity="center_vertical"
                android:text="长期统计"
                android:textColor="@color/color_text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="66dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_core_streak" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="最长连续不破戒"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvLongestNoBreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0 天"
                        android:textColor="@color/color_text_main"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="44dp"
                    android:background="@color/exp_divider" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_core_no_break" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本月完成日记"
                        android:textColor="@color/color_text_sub"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvMonthlyDiaryCompletion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0 / 0"
                        android:textColor="@color/checkin_done"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
