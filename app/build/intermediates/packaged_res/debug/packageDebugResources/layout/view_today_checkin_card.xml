<?xml version="1.0" encoding="utf-8"?>
<!-- 今日打卡进度卡片：ConstraintLayout 版本 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/todayCheckinCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_realm_status_card"
    android:clipToOutline="true"
    android:elevation="3dp"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <!-- 第一行三等分辅助线 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineColumnOne"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3333" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineColumnTwo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6666" />

    <!-- 第二行居中辅助线 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.1666" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.8333" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvCheckinTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:includeFontPadding="false"
        android:text="@string/today_checkin_progress"
        android:textColor="@color/checkin_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvCheckinCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 已完成数量 -->
    <TextView
        android:id="@+id/tvCheckinCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3/5"
        android:textColor="@color/checkin_done"
        android:textSize="10sp"
        app:layout_constraintBaseline_toBaselineOf="@id/tvCheckinTitle"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="HardcodedText" />

    <!-- 阅读 -->
    <LinearLayout
        android:id="@+id/itemReading"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintEnd_toStartOf="@id/guidelineColumnOne"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCheckinTitle">

        <ImageView
            android:id="@+id/ivReadingStatus"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/checkin_reading"
            android:src="@drawable/ic_checkin_reading_done" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/checkin_reading"
            android:textColor="@color/checkin_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvReadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/checkin_completed"
            android:textColor="@color/checkin_done"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 运动 -->
    <LinearLayout
        android:id="@+id/itemExercise"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintEnd_toStartOf="@id/guidelineColumnTwo"
        app:layout_constraintStart_toStartOf="@id/guidelineColumnOne"
        app:layout_constraintTop_toTopOf="@id/itemReading">

        <ImageView
            android:id="@+id/ivExerciseStatus"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/checkin_exercise"
            android:src="@drawable/ic_checkin_exercise_done" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/checkin_exercise"
            android:textColor="@color/checkin_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvExerciseStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/checkin_completed"
            android:textColor="@color/checkin_done"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 作息 -->
    <LinearLayout
        android:id="@+id/itemSleep"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineColumnTwo"
        app:layout_constraintTop_toTopOf="@id/itemReading">

        <ImageView
            android:id="@+id/ivSleepStatus"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/checkin_sleep"
            android:src="@drawable/ic_checkin_sleep_pending" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/checkin_sleep"
            android:textColor="@color/checkin_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvSleepStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/checkin_pending"
            android:textColor="@color/checkin_pending"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 单词 -->
    <LinearLayout
        android:id="@+id/itemWord"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineBottomCenter"
        app:layout_constraintStart_toStartOf="@id/guidelineBottomStart"
        app:layout_constraintTop_toBottomOf="@id/itemReading">

        <ImageView
            android:id="@+id/ivWordStatus"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/checkin_word"
            android:src="@drawable/ic_checkin_word_done" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/checkin_word"
            android:textColor="@color/checkin_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvWordStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/checkin_completed"
            android:textColor="@color/checkin_done"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- 日记 -->
    <LinearLayout
        android:id="@+id/itemDiary"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineBottomEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineBottomCenter"
        app:layout_constraintTop_toBottomOf="@id/itemReading">

        <ImageView
            android:id="@+id/ivDiaryStatus"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/checkin_diary"
            android:src="@drawable/ic_checkin_diary_pending" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/checkin_diary"
            android:textColor="@color/checkin_text_primary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvDiaryStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/checkin_pending"
            android:textColor="@color/checkin_pending"
            android:textSize="10sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>