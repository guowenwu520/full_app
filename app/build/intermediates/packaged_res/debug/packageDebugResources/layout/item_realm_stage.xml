<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/realmStageRoot"
    android:layout_width="70dp"
    android:layout_height="90dp"
    android:layout_marginHorizontal="2dp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="58dp"
        android:layout_height="58dp">

        <ImageView
            android:id="@+id/ivRealmStageIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivRealmStageLock"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:contentDescription="@null"
            android:src="@drawable/ic_medal_lock"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvRealmStageName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/color_text_main"
        android:textSize="10sp" />

    <View
        android:id="@+id/realmStageIndicator"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginTop="3dp"
        android:background="@drawable/bg_realm_indicator"
        android:visibility="invisible" />
</LinearLayout>
