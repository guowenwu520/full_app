<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="4dp">

    <ImageView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_ew_running" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="9dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvExerciseHistoryType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="@color/color_text_main"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvExerciseHistoryDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/color_text_sub"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvExerciseHistoryMetric"
        android:layout_width="86dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/color_text_main"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvExerciseHistoryCalories"
        android:layout_width="76dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/color_text_main"
        android:textSize="11sp" />

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:contentDescription="@null"
        android:padding="6dp"
        android:src="@drawable/ic_arrow_right_small" />
</LinearLayout>
