<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bookDetailNoteItem"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <TextView
        android:id="@+id/tvDetailNotePage"
        android:layout_width="62dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_book_note_page_badge"
        android:gravity="center"
        android:textColor="@color/color_text_main"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDetailNoteContent"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_book_detail_row"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:textColor="@color/color_text_main"
        android:textSize="11sp" />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="42dp"
        android:contentDescription="@null"
        android:padding="7dp"
        android:src="@drawable/ic_arrow_right_small" />
</LinearLayout>
