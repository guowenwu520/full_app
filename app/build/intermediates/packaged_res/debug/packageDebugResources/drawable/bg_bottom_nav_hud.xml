<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp"><shape><corners android:topLeftRadius="6dp" android:topRightRadius="6dp"/><solid android:color="#240D4560"/></shape></item>
    <item>
        <shape>
            <corners android:topLeftRadius="6dp" android:topRightRadius="6dp"/>
            <gradient android:startColor="#F8FFFFFF" android:centerColor="#F2FCFFFF" android:endColor="#D8F6FBFF" android:angle="270"/>
            <stroke android:width="1dp" android:color="#F6FFFFFF"/>
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="1dp">
        <shape><corners android:topLeftRadius="6dp" android:topRightRadius="6dp"/><stroke android:width="1dp" android:color="#C4E9F7"/></shape>
    </item>
</layer-list>
