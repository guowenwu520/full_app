<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
        <shape>
            <corners android:radius="26dp"/>
            <solid android:color="#160A4A62"/>
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="26dp"/>
            <gradient android:startColor="#F8FFFFFF" android:centerColor="#E8F9FDFF" android:endColor="#CFF6FBFF" android:angle="315"/>
            <stroke android:width="1dp" android:color="#F2FFFFFF"/>
            <padding android:left="18dp" android:right="18dp" android:top="16dp" android:bottom="16dp"/>
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape>
            <corners android:radius="25dp"/>
            <stroke android:width="1dp" android:color="#BDE8F7"/>
        </shape>
    </item>
</layer-list>
